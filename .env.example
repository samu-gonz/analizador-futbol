# ─────────────────────────────────────────────────────────────
# SportsAPI Pro — Partidos, clasificación, calendario Mundial
# https://sportsapipro.com/dashboard
# ─────────────────────────────────────────────────────────────
SPORTS_API_PRO_BASE_URL=https://api.sportsapipro.com/
SPORTS_API_PRO_KEY=tu_clave_fapi_aqui

# ─────────────────────────────────────────────────────────────
# The Odds API — Cuotas REALES de Bet365 (todos los mercados)
# https://the-odds-api.com  →  "Get API Key" (plan gratis)
#
# Plan gratuito: 500 créditos/mes, sin tarjeta.
# Con la optimización del Mundial: ~6 créditos cada 30 min (caché compartida).
#
# Pasos:
#   1. Regístrate en https://the-odds-api.com
#   2. Copia tu API key del email o del dashboard
#   3. Pégala abajo y reinicia: npm run dev:clean
# ─────────────────────────────────────────────────────────────
THE_ODDS_API_KEY=tu_clave_odds_api_aqui

# ─────────────────────────────────────────────────────────────
# OddsPortal scraping — Fallback local cuando Odds API sin créditos
# Solo funciona en desarrollo local (no en Vercel). Requiere: npm install
#
# ODDS_PORTAL_SCRAPING_ENABLED=true   → activar en npm run dev
# ODDS_PORTAL_BASE_URL=https://www.cuotasahora.com  (España) u oddsportal.com
# ─────────────────────────────────────────────────────────────
ODDS_PORTAL_SCRAPING_ENABLED=true
ODDS_PORTAL_BASE_URL=https://www.cuotasahora.com
